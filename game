<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Bug Invasion: Last Stand</title>

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap" rel="stylesheet">

<style>
body { margin:0; overflow:hidden; background:black; font-family:Orbitron; color:white;}
canvas { display:none; cursor:none;}

#loading {
  position:absolute; width:100%; height:100%;
  display:flex; justify-content:center; align-items:center;
  flex-direction:column; background:black;
}

#loading img { width:120px; animation: float 2s infinite;}
@keyframes float {50%{transform:translateY(-15px);}}

#story { display:none; position:absolute; width:100%; height:100%;
  display:flex; justify-content:center; align-items:center; text-align:center;}

#hud { position:absolute; top:20px; left:20px;}
.bar { width:200px; height:20px; background:#222;}
.bar-inner { height:100%; background:#00ffe1;}

#crosshair {
  position:absolute;
  width:20px; height:20px;
  border:2px solid #00ffe1;
  border-radius:50%;
  pointer-events:none;
}
</style>
</head>

<body>

<div id="loading">
  <img src="tv.png">
  <div>LOADING...</div>
</div>

<div id="story">
  <div>
    <h1>BUG INVASION</h1>
    <p>You are the last soldier.<br>Survive. Build. Fight.</p>
    <p>Press any key</p>
  </div>
</div>

<div id="hud">
  <div class="bar"><div id="hp" class="bar-inner"></div></div>
  <div id="wave">Wave: 1</div>
</div>

<div id="crosshair"></div>

<canvas id="game"></canvas>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");
canvas.width = innerWidth;
canvas.height = innerHeight;

/* IMAGES */
const playerImg = new Image(); playerImg.src="jonesy.png";
const bugImg = new Image(); bugImg.src="bug.png";

/* STATE */
let player = {x:0,y:0,health:100};
let camera = {x:0,y:0};
let enemies=[], bullets=[], particles=[], walls=[];
let wave=1, running=false;

/* INPUT */
let keys={}, mouse={x:0,y:0};
document.addEventListener("keydown",e=>{keys[e.key.toLowerCase()]=true; if(!running)start();});
document.addEventListener("keyup",e=>keys[e.key.toLowerCase()]=false);
document.addEventListener("mousemove",e=>{
  mouse.x=e.clientX; mouse.y=e.clientY;
  document.getElementById("crosshair").style.left=mouse.x+"px";
  document.getElementById("crosshair").style.top=mouse.y+"px";
});

/* SHOOT */
setInterval(()=>{
  if(!running) return;
  bullets.push({
    x:player.x,
    y:player.y,
    dx:(mouse.x-canvas.width/2)/10,
    dy:(mouse.y-canvas.height/2)/10
  });
},150);

/* BUILD */
document.addEventListener("keydown",e=>{
  if(e.key==="e"){
    walls.push({x:player.x,y:player.y});
  }
});

/* LOADING */
setTimeout(()=>{
  document.getElementById("loading").style.display="none";
  document.getElementById("story").style.display="flex";
},2500);

function start(){
  running=true;
  document.getElementById("story").style.display="none";
  canvas.style.display="block";
  spawnWave();
  update();
}

/* SPAWN */
function spawnWave(){
  for(let i=0;i<wave*5;i++){
    enemies.push({
      x:Math.random()*2000-1000,
      y:Math.random()*2000-1000,
      type:Math.random()
    });
  }
}

/* DRAW WORLD */
function drawGrid(){
  ctx.strokeStyle="rgba(0,255,200,0.1)";
  for(let x=-2000;x<2000;x+=100){
    ctx.beginPath();
    ctx.moveTo(x-camera.x, -2000-camera.y);
    ctx.lineTo(x-camera.x, 2000-camera.y);
    ctx.stroke();
  }
}

/* PLAYER */
function drawPlayer(){
  ctx.drawImage(playerImg,
    canvas.width/2-30,
    canvas.height/2-30,
    60,60);
}

/* BULLETS */
function drawBullets(){
  bullets.forEach((b,i)=>{
    b.x+=b.dx; b.y+=b.dy;
    ctx.fillStyle="white";
    ctx.fillRect(b.x-camera.x,b.y-camera.y,4,4);
  });
}

/* PARTICLES */
function spawnParticles(x,y){
  for(let i=0;i<10;i++){
    particles.push({x,y,dx:Math.random()*4-2,dy:Math.random()*4-2});
  }
}
function drawParticles(){
  particles.forEach((p,i)=>{
    p.x+=p.dx; p.y+=p.dy;
    ctx.fillRect(p.x-camera.x,p.y-camera.y,2,2);
  });
}

/* ENEMIES */
function drawEnemies(){
  enemies.forEach((e,i)=>{
    let dx=player.x-e.x, dy=player.y-e.y;
    let dist=Math.hypot(dx,dy);

    let speed = e.type<0.3?2 : e.type<0.6?1 : 0.5;
    e.x += dx/dist * speed;
    e.y += dy/dist * speed;

    ctx.drawImage(bugImg,e.x-camera.x-20,e.y-camera.y-20,40,40);

    if(dist<40) player.health-=0.2;

    bullets.forEach((b,bi)=>{
      if(Math.hypot(b.x-e.x,b.y-e.y)<30){
        spawnParticles(e.x,e.y);
        enemies.splice(i,1);
        bullets.splice(bi,1);
      }
    });
  });

  if(enemies.length===0){
    wave++;
    document.getElementById("wave").textContent="Wave: "+wave;
    spawnWave();
  }
}

/* WALLS */
function drawWalls(){
  ctx.fillStyle="#00ffe1";
  walls.forEach(w=>{
    ctx.fillRect(w.x-camera.x-20,w.y-camera.y-20,40,40);
  });
}

/* MOVE */
function move(){
  if(keys["w"]) player.y-=4;
  if(keys["s"]) player.y+=4;
  if(keys["a"]) player.x-=4;
  if(keys["d"]) player.x+=4;

  camera.x = player.x - canvas.width/2;
  camera.y = player.y - canvas.height/2;
}

/* LOOP */
function update(){
  ctx.clearRect(0,0,canvas.width,canvas.height);

  drawGrid();
  move();
  drawWalls();
  drawEnemies();
  drawBullets();
  drawParticles();
  drawPlayer();

  document.getElementById("hp").style.width=player.health+"%";

  if(player.health<=0){
    alert("You survived "+wave+" waves");
    location.reload();
  }

  requestAnimationFrame(update);
}
</script>

</body>
</html>
